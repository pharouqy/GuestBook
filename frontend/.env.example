# Variables d'environnement Frontend — MODÈLE
# Copier vers .env.local (jamais committé)

# ── API Backend ────────────────────────────────────────────────────────────────
# URL de l'API Express (côté serveur Next.js uniquement — pas de NEXT_PUBLIC_)
# Ce secret ne sera JAMAIS exposé au navigateur
API_URL=http://localhost:4000

# ── Variables publiques (exposées au navigateur) ───────────────────────────────
# ATTENTION : Tout ce qui commence par NEXT_PUBLIC_ est visible dans le bundle JS
# Ne jamais mettre de secrets ici
NEXT_PUBLIC_APP_NAME=Livre d'Or
NEXT_PUBLIC_APP_URL=http://localhost:3000
