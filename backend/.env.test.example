# Variables d'environnement — TESTS
# Ce fichier est chargé par Vitest via tests/setup.ts
# NE PAS committer ce fichier — uniquement .env.test.example

NODE_ENV=test
PORT=4001
API_VERSION=v1

MONGODB_URI=mongodb://localhost:27017/guestbook_test
MONGODB_URI_TEST=mongodb://localhost:27017/guestbook_test

# Clés de test — NE PAS réutiliser en production
JWT_ACCESS_SECRET=test-access-secret-minimum-32-characters-long
JWT_REFRESH_SECRET=test-refresh-secret-minimum-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

LOG_LEVEL=silent
