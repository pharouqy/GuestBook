# Variables d'environnement Backend — MODÈLE
# Copier ce fichier vers .env et remplir les valeurs réelles
# NE JAMAIS committer .env dans Git

# ── Serveur ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1

# ── Base de données MongoDB ────────────────────────────────────────────────────
# Format : mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>
MONGODB_URI=mongodb://localhost:27017/guestbook_dev
MONGODB_URI_TEST=mongodb://localhost:27017/guestbook_test

# ── JWT (JSON Web Tokens) ─────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REMPLACER_PAR_UNE_VRAIE_CLÉ_64_OCTETS_MINIMUM
JWT_REFRESH_SECRET=REMPLACER_PAR_UNE_AUTRE_VRAIE_CLÉ_64_OCTETS_MINIMUM
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Admin initial ─────────────────────────────────────────────────────────────
# Utilisé uniquement pour le seed de la base de données (script init)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=REMPLACER_PAR_MOT_DE_PASSE_FORT

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL du frontend Next.js (sans slash final)
CORS_ORIGIN=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
